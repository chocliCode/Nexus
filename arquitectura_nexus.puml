' ================================================================
'  DIAGRAMA DE SECUENCIA: Transaccion ACID — Completar OKR
' ================================================================

@startuml Nexus_Secuencia_CompletarOKR

title Diagrama de Secuencia — Completar OKR (Transaccion ACID)

actor "Padawan / Mentor" as user
participant "React SPA\n(OKRPage)" as frontend
participant "Axios\n(api.ts)" as axios
participant "Express Router\n(okr.routes.ts)" as router
participant "authMiddleware" as auth
participant "okr.controller.ts\ncompleteOKR()" as ctrl
database "PostgreSQL\n(pg Pool)" as db

user -> frontend : Click "Completar OKR"
frontend -> axios : okrService.complete(okrId, {valor_actual, nota_cierre})
axios -> router : PATCH /api/v1/okrs/:okrId/complete\n[Authorization: Bearer <JWT>]

router -> auth : authMiddleware
auth -> auth : jwt.verify(token)
auth -> router : req.user = {userId, email, rol}

router -> ctrl : completeOKR(req, res, next)

ctrl -> db : SELECT okr + matching + mentor + padawan\n(Verificar propiedad)

alt OKR no encontrado
  ctrl -> frontend : 404 OKR_NOT_FOUND
else Estado != EnProgreso
  ctrl -> frontend : 409 INVALID_STATE_TRANSITION
else Todo valido
  ctrl -> db : BEGIN TRANSACTION
  ctrl -> db : UPDATE okr SET estado='Completado'
  ctrl -> db : INSERT okr_historial (audit trail)
  ctrl -> db : UPDATE perfil_aprendiz\nSET score += 12 (cap 100)
  ctrl -> db : COMMIT

  ctrl -> ctrl : setImmediate() → Notificacion asincrona

  ctrl -> db : SELECT okr + nuevo_score
  ctrl -> frontend : 200 {success: true, okr: {...}}
end

frontend -> user : Actualiza UI con\nnuevo estado y score

@enduml


' ================================================================
'  DIAGRAMA DE DESPLIEGUE
' ================================================================

@startuml Nexus_Despliegue

title Nexus — Diagrama de Despliegue

node "Maquina de Desarrollo" {
  component "Docker Compose" as dc {
    artifact "Frontend Container\nReact + Vite\nPuerto: 5174" as frontC
    artifact "Backend Container\nNode.js + Express\nPuerto: 3001" as backC
    artifact "PostgreSQL Container\nPostgres 16 Alpine\nPuerto: 5432" as dbC
  }
}

cloud "Azure Cloud" {
  node "Azure Static Web Apps" as azStatic {
    artifact "Frontend Build\n(React SPA)" as azFront
  }
  node "Azure App Service" as azApp {
    artifact "Backend API\n(Docker)" as azBack
  }
  database "Azure PostgreSQL\n(Produccion)" as azDB
}

cloud "GitHub" {
  artifact "GitHub Actions\nCI/CD Pipeline" as ghActions
}

frontC --> backC : HTTP :3001
backC --> dbC : TCP :5432

ghActions --> azStatic : Deploy frontend
ghActions --> azApp : Deploy backend

azFront --> azBack : HTTPS /api/v1
azBack --> azDB : TCP/SSL

@enduml
