{
  "name": "nexus-backend",
  "version": "1.0.0",
  "description": "NEXUS API — Plataforma de mentoría 1-a-1",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest --forceExit",
    "test:unit": "jest --config jest.unit.config.js",
    "test:load": "artillery run tests/load/load-mixed.yml",
    "test:load:auth": "artillery run tests/load/load-auth.yml",
    "test:load:sessions": "artillery run tests/load/load-sessions.yml",
    "test:load:vacancies": "artillery run tests/load/load-vacancies.yml",
    "test:load:notifications": "artillery run tests/load/load-notifications-ia.yml",
    "test:stress": "artillery run tests/stress/stress-limits.yml",
    "test:stress:auth": "artillery run tests/stress/stress-auth.yml",
    "test:stress:db": "artillery run tests/stress/stress-db.yml",
    "test:stress:spike": "artillery run tests/stress/stress-spike.yml",
    "test:stress:endurance": "artillery run tests/stress/stress-endurance.yml",
    "test:security": "jest --testPathPattern=security --forceExit",
    "test:smoke": "jest --testPathPattern=smoke --forceExit",
    "test:acceptance": "jest --testPathPattern=acceptance --runInBand --forceExit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "pg": "^8.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "artillery": "^2.0.33",
    "exceljs": "^4.4.0",
    "jest": "^29.7.0",
    "jest-cucumber": "^4.5.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
